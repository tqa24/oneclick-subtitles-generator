# NPM Configuration to reduce verbosity and warnings for end users
# This helps make the installation process cleaner and less overwhelming

# Reduce audit warnings for dependencies we can't control
audit-level=high

# Disable funding messages
fund=false

# Reduce progress output
progress=false

# Disable update notifier for npm itself
update-notifier=false

# Set log level to warn to reduce info messages
loglevel=warn

# Commit package-lock.json for reproducible installs (npm ci reads it).
# (package-lock=false was removed so the lockfile is written + honored.)

# Disable save-exact warnings
save-exact=false

# Disable engine-strict to avoid Node.js version warnings for dependencies
engine-strict=false
